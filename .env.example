# Copy to `.env` next to docker-compose.yml (gitignored) or inject the same
# variables via your orchestrator. Values are not baked into Docker images.

# MongoDB (Compose sets MONGO_URI/MONGO_DB_NAME on the api service for the
# bundled mongo service; override here if you use Atlas or another host.)
# MONGO_URI=mongodb://mongo:27017
# MONGO_DB_NAME=yoga

# Auth (required when using auth routes; see app/auth/settings.py)
JWT_SECRET=
GOOGLE_CLIENT_ID=
ACCESS_TTL_MINUTES=15
REFRESH_TTL_DAYS=30
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
USER_DAILY_LLM_USD_CAP=10.0

# LLM
OPENAI_API_KEY=

# Optional: Sentry (see app/globals/exception_handlers.py)
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0

# Optional: prompts (see app/prompts/version.py)
# PROMPT_VERSION=v4

# Optional: longer wait for Mongo on slow hosts (docker_wait_mongo.py)
# MONGO_WAIT_TIMEOUT=120
